from __future__ import annotations
import sys, threading, tkinter as tk
from tkinter import ttk, messagebox
import pygame

import config as cfg
from main import configure as main_configure, run_frame as main_run_frame, \
                 AGENT_CLASSES as main_agent_classes, init_pygame_surface as main_init_pygame_surface, \
                 get_simulation_stats
# Import agent_base_movement_params to get defaults for GUI
from agent_module import set_parameters as set_agent_parameters, movement as agent_base_movement_params
from math_module import set_environment_density, set_frame_dt, FRAME_DT # Import FRAME_DT for default

class VarD(tk.DoubleVar):
    def __init__(self, v: float): super().__init__(value=round(v, 4)) # Round for display
class VarI(tk.IntVar):
    def __init__(self, v: int): super().__init__(value=v)

class SimGUI:
    def __init__(self):
        self.root = tk.Tk(); self.root.title("Agent Sim Control Panel - Vector Physics")
        self.root.geometry("450x700+50+50") # Wider for more controls

        self.notebook = ttk.Notebook(self.root)
        self.notebook.pack(fill="both", expand=True, padx=5, pady=5)

        self.controls_tab = ttk.Frame(self.notebook); self.notebook.add(self.controls_tab, text="Controls")
        self.physics_tab = ttk.Frame(self.notebook); self.notebook.add(self.physics_tab, text="Physics")
        self.status_tab = ttk.Frame(self.notebook); self.notebook.add(self.status_tab, text="Status")

        self._tk_vars = {
            "threshold": VarD(0.5),
            # "speed" slider now controls initial_target_thrust_normalized
            "initial_thrust": VarD(agent_base_movement_params[0]),
            # "turn_rate" slider controls base_turn_rate_deg_per_dt for agents
            "base_turn_rate_dt": VarD(agent_base_movement_params[1]),
            "accel_step": VarD(0.1), # Corresponds to AGENT_CONFIG["ACCEL_STEP"]
            "decel_step": VarD(0.1), # Corresponds to AGENT_CONFIG["DECEL_STEP"]
            "fps": VarI(int(1/FRAME_DT if FRAME_DT > 0 else 60)), # FPS now linked to FRAME_DT
            "n_agents": VarI(1),
            "spawn_x": VarD(cfg.WINDOW_W / 2),
            "spawn_y": VarD(cfg.WINDOW_H / 2),
            # Physics specific
            "env_density": VarD(1.225), # Default from math_module
            "agent_mass": VarD(cfg.AGENT_DEFAULT_MASS),
            "agent_max_thrust_force": VarD(cfg.AGENT_DEFAULT_MAX_THRUST),
            "agent_drag_coeff": VarD(cfg.AGENT_DEFAULT_DRAG_COEFF),
            "agent_frontal_area": VarD(cfg.AGENT_DEFAULT_FRONTAL_AREA),
            "input_time_scale": VarI(30), # For AGENT_CONFIG
        }

        self._build_controls_tab(self.controls_tab)
        self._build_physics_tab(self.physics_tab)
        self._build_status_tab(self.status_tab)

        self.running_simulation = False; self.sim_thread = None; self.pygame_surface = None
        self.root.protocol("WM_DELETE_WINDOW", self.quit_application)
        self._periodic_status_update()

    def _add_slider_entry(self, parent, key, label_text, from_, to_):
        row_frame = ttk.Frame(parent); row_frame.pack(fill="x", pady=2)
        ttk.Label(row_frame, text=label_text, width=28).pack(side="left")
        var = self._tk_vars[key]
        ttk.Scale(row_frame, variable=var, from_=from_, to=to_, orient="horizontal").pack(side="left", fill="x", expand=True, padx=5)
        ttk.Entry(row_frame, textvariable=var, width=7).pack(side="left")

    def _build_controls_tab(self, parent_tab):
        main_frame = ttk.Frame(parent_tab, padding=10); main_frame.pack(fill="both", expand=True)

        agent_logic_frame = ttk.LabelFrame(main_frame, text="Agent Logic Parameters"); agent_logic_frame.pack(fill="x", pady=5)
        self._add_slider_entry(agent_logic_frame, "threshold", "Food Sense Threshold", 0, 1)
        self._add_slider_entry(agent_logic_frame, "accel_step", "Thrust Accel Step (norm)", 0.01, 0.5)
        self._add_slider_entry(agent_logic_frame, "decel_step", "Thrust Decel Step (norm)", 0.01, 0.5)
        self._add_slider_entry(agent_logic_frame, "input_time_scale", "Input Avg Time Scale (frames)", 5, 100)


        agent_motion_frame = ttk.LabelFrame(main_frame, text="Base Agent Motion"); agent_motion_frame.pack(fill="x", pady=5)
        self._add_slider_entry(agent_motion_frame, "initial_thrust", "Initial Thrust (0-1)", 0.0, 1.0)
        self._add_slider_entry(agent_motion_frame, "base_turn_rate_dt", "Base Turn Rate (°/frame)", 0.0, 30.0)

        world_setup_frame = ttk.LabelFrame(main_frame, text="World & Agent Setup"); world_setup_frame.pack(fill="x", pady=5)
        # Num Agents
        f = ttk.Frame(world_setup_frame); f.pack(fill="x", pady=2); ttk.Label(f, text="# Agents", width=28).pack(side="left")
        ttk.Spinbox(f, from_=1, to=50, textvariable=self._tk_vars["n_agents"], width=10).pack(side="left", fill="x", expand=True, padx=5)
        # Spawn X, Y
        self._add_slider_entry(world_setup_frame, "spawn_x", "Spawn X", 0, cfg.WINDOW_W)
        self._add_slider_entry(world_setup_frame, "spawn_y", "Spawn Y", 0, cfg.WINDOW_H)
        # Food Preset
        f = ttk.Frame(world_setup_frame); f.pack(fill="x", pady=2); ttk.Label(f, text="Food Preset", width=28).pack(side="left")
        self.food_sel = ttk.Combobox(f, values=list(cfg.FOOD_PRESETS.keys()), state="readonly", width=18)
        self.food_sel.current(0); self.food_sel.pack(side="left", fill="x", expand=True, padx=5)
        # Agent Type
        f = ttk.Frame(world_setup_frame); f.pack(fill="x", pady=2); ttk.Label(f, text="Agent Type", width=28).pack(side="left")
        self.agent_sel = ttk.Combobox(f, values=list(main_agent_classes.keys()), state="readonly", width=18)
        self.agent_sel.current(0); self.agent_sel.pack(side="left", fill="x", expand=True, padx=5)

        # Sim Control Buttons (at the bottom of this tab)
        buttons_frame = ttk.Frame(main_frame); buttons_frame.pack(fill="x", pady=10, side="bottom")
        self.start_button = ttk.Button(buttons_frame, text="Start Simulation", command=self.start_simulation)
        self.start_button.pack(side="left", expand=True, fill="x", padx=5)
        self.stop_button = ttk.Button(buttons_frame, text="Stop Simulation", command=self.stop_simulation, state="disabled")
        self.stop_button.pack(side="left", expand=True, fill="x", padx=5)
        ttk.Button(buttons_frame, text="Quit App", command=self.quit_application).pack(side="left", expand=True, fill="x", padx=5)


    def _build_physics_tab(self, parent_tab):
        main_frame = ttk.Frame(parent_tab, padding=10); main_frame.pack(fill="both", expand=True)

        env_frame = ttk.LabelFrame(main_frame, text="Environment Physics"); env_frame.pack(fill="x", pady=5)
        self._add_slider_entry(env_frame, "fps", "Target FPS (sets ∆t)", 10, 240)
        self._add_slider_entry(env_frame, "env_density", "Environment Density (kg/m³)", 0.0, 2.0)

        agent_phys_frame = ttk.LabelFrame(main_frame, text="Agent Base Physics Props"); agent_phys_frame.pack(fill="x", pady=5)
        self._add_slider_entry(agent_phys_frame, "agent_mass", "Agent Mass (kg)", 0.1, 10.0)
        self._add_slider_entry(agent_phys_frame, "agent_max_thrust_force", "Max Thrust Force (N)", 1.0, 100.0)
        self._add_slider_entry(agent_phys_frame, "agent_drag_coeff", "Drag Coeff (Cd)", 0.0, 2.0)
        self._add_slider_entry(agent_phys_frame, "agent_frontal_area", "Frontal Area (m²)", 0.001, 0.1)

    def _build_status_tab(self, parent_tab): # Same as before
        status_frame = ttk.LabelFrame(parent_tab, text="Live Simulation Status", padding=10)
        status_frame.pack(fill="both", expand=True)
        self.sim_status_var = tk.StringVar(value="Simulation: Idle")
        ttk.Label(status_frame, textvariable=self.sim_status_var, font=("Arial", 12)).pack(anchor="w", pady=5)
        self.total_food_var = tk.StringVar(value="Total Food Items: N/A")
        ttk.Label(status_frame, textvariable=self.total_food_var).pack(anchor="w", pady=2)
        self.agents_active_var = tk.StringVar(value="Active Agents: N/A")
        ttk.Label(status_frame, textvariable=self.agents_active_var).pack(anchor="w", pady=2)
        self.food_eaten_var = tk.StringVar(value="Food Eaten This Run: N/A")
        ttk.Label(status_frame, textvariable=self.food_eaten_var).pack(anchor="w", pady=2)
        ttk.Separator(status_frame, orient='horizontal').pack(fill='x', pady=10)
        log_frame = ttk.LabelFrame(status_frame, text="Event Log"); log_frame.pack(fill="both", expand=True, pady=5)
        self.log_text = tk.Text(log_frame, height=8, state="disabled", wrap="word"); log_scroll = ttk.Scrollbar(log_frame, command=self.log_text.yview)
        self.log_text.config(yscrollcommand=log_scroll.set); log_scroll.pack(side="right", fill="y"); self.log_text.pack(side="left", fill="both", expand=True)
        self._add_log_message("GUI Initialized (Vector Physics).")

    def _add_log_message(self, message): # Same
        if hasattr(self, 'log_text'):
            self.log_text.config(state="normal"); self.log_text.insert(tk.END, f"{message}\n"); self.log_text.see(tk.END); self.log_text.config(state="disabled")

    def _apply_settings(self):
        self._add_log_message("Applying settings...")
        # Agent Logic parameters for AGENT_CONFIG
        set_agent_parameters(
            CONSTANT_THRESHOLD=self._tk_vars["threshold"].get(),
            ACCEL_STEP=self._tk_vars["accel_step"].get(),
            DECEL_STEP=self._tk_vars["decel_step"].get(),
            INPUT_TIME_SCALE_DEFAULT=self._tk_vars["input_time_scale"].get()
        )

        # Physics Environment parameters for math_module
        fps_val = self._tk_vars["fps"].get()
        set_frame_dt(1.0 / fps_val if fps_val > 0 else (1.0/60.0)) # Update global FRAME_DT
        set_environment_density(self._tk_vars["env_density"].get())

        # Agent Base Physics Props (update config.py defaults that SimAgent will use on reset)
        cfg.AGENT_DEFAULT_MASS = self._tk_vars["agent_mass"].get()
        cfg.AGENT_DEFAULT_MAX_THRUST = self._tk_vars["agent_max_thrust_force"].get()
        cfg.AGENT_DEFAULT_DRAG_COEFF = self._tk_vars["agent_drag_coeff"].get()
        cfg.AGENT_DEFAULT_FRONTAL_AREA = self._tk_vars["agent_frontal_area"].get()

        # Base motion parameters for new agents (initial thrust and turn rate)
        # These are passed to main.configure and then to SimAgent constructor
        initial_thrust_val = self._tk_vars["initial_thrust"].get()
        base_turn_rate_val = self._tk_vars["base_turn_rate_dt"].get()

        # Update the global `agent_base_movement_params` in agent_module if agents read from it directly
        # This is a bit indirect. Better to pass values directly to SimAgent construction via main.configure.
        agent_base_movement_params[0] = initial_thrust_val
        agent_base_movement_params[1] = base_turn_rate_val


        spawn_point = (self._tk_vars["spawn_x"].get(), self._tk_vars["spawn_y"].get())
        main_configure(
            food_preset=self.food_sel.get(),
            agent_type=self.agent_sel.get(),
            n_agents=int(self._tk_vars["n_agents"].get()),
            spawn_point=spawn_point,
            initial_thrust=initial_thrust_val, # Pass to main.configure
            base_turn_deg_dt=base_turn_rate_val  # Pass to main.configure
        )
        self._add_log_message(f"World configured. FPS: {fps_val}, Thrust: {initial_thrust_val:.2f}, TurnRate: {base_turn_rate_val:.2f}°/frame")

    # start_simulation, stop_simulation, _simulation_loop_thread, etc. remain the same
    # as the previous "separate Pygame window with status tab" version.
    # Ensure clk.tick uses self._tk_vars["fps"].get()
    def start_simulation(self): # Unchanged
        if self.running_simulation: self.stop_simulation()
        self._apply_settings()
        self.running_simulation = True; self.start_button.config(state="disabled"); self.stop_button.config(state="normal")
        self.sim_status_var.set("Simulation: Starting..."); self._add_log_message("Starting simulation thread...")
        self.sim_thread = threading.Thread(target=self._simulation_loop_thread, daemon=True); self.sim_thread.start()

    def stop_simulation(self): # Unchanged
        if not self.running_simulation: return
        self._add_log_message("Stopping simulation..."); self.sim_status_var.set("Simulation: Stopping...")
        self.running_simulation = False
        if self.sim_thread and self.sim_thread.is_alive():
            try: self.sim_thread.join(timeout=2.0)
            except RuntimeError: pass
        self.sim_thread = None; self.pygame_surface = None
        self.start_button.config(state="normal"); self.stop_button.config(state="disabled")
        self.sim_status_var.set("Simulation: Idle"); self._add_log_message("Simulation stopped.")

    def _simulation_loop_thread(self): # Ensure FPS is read correctly
        self._add_log_message("Simulation thread active.")
        pygame.init()
        try:
            self.pygame_surface = pygame.display.set_mode((cfg.WINDOW_W, cfg.WINDOW_H))
            pygame.display.set_caption("Agent Simulation Visuals (Vector Physics)")
            self.root.after(0, lambda: self.sim_status_var.set("Simulation: Running"))
            self._add_log_message(f"Pygame window ({cfg.WINDOW_W}x{cfg.WINDOW_H}) created.")
        except pygame.error as e:
            self.root.after(0, lambda: self._handle_pygame_error_gui(str(e)))
            if pygame.get_init(): pygame.quit(); self.running_simulation = False; return
        main_init_pygame_surface(self.pygame_surface)
        clk = pygame.time.Clock()
        current_fps_target = 60 # Fallback
        while self.running_simulation:
            for e in pygame.event.get():
                if e.type == pygame.QUIT:
                    self.running_simulation = False; self.root.after(0, self.stop_simulation); break
            if not self.running_simulation: break
            main_run_frame()
            pygame.display.flip()
            try: current_fps_target = self._tk_vars["fps"].get() # Get FPS from GUI var
            except tk.TclError: self.running_simulation = False; break # GUI might be closing
            clk.tick(current_fps_target)
        if pygame.get_init(): pygame.quit()
        self._add_log_message("Simulation thread finished, Pygame quit.")
        self.root.after(0, self._ensure_gui_stopped_state)

    def _handle_pygame_error_gui(self, error_msg): # Unchanged
        self._add_log_message(f"Pygame Error: {error_msg}")
        messagebox.showerror("Pygame Error", f"Could not initialize Pygame display: {error_msg}\nSimulation visuals will not be available.")
        self.start_button.config(state="normal"); self.stop_button.config(state="disabled"); self.sim_status_var.set("Simulation: Error")

    def _ensure_gui_stopped_state(self): # Unchanged
        if not self.running_simulation:
            self.start_button.config(state="normal"); self.stop_button.config(state="disabled")
            if self.sim_status_var.get() != "Simulation: Error": self.sim_status_var.set("Simulation: Idle")

    def _periodic_status_update(self): # Unchanged
        if not self.root.winfo_exists(): return
        if self.running_simulation:
            try:
                stats = get_simulation_stats()
                self.total_food_var.set(f"Total Food Items: {stats.get('total_food', 'N/A')}")
                self.agents_active_var.set(f"Active Agents: {stats.get('active_agents', 'N/A')}")
                self.food_eaten_var.set(f"Food Eaten This Run: {stats.get('food_eaten_run', 'N/A')}")
            except Exception: pass
        else:
            self.total_food_var.set("Total Food Items: N/A (Not Running)"); self.agents_active_var.set("Active Agents: N/A (Not Running)"); self.food_eaten_var.set("Food Eaten This Run: N/A (Not Running)")
        self.root.after(1000, self._periodic_status_update)

    def quit_application(self): self._add_log_message("Quit application requested."); self.stop_simulation(); self._destroy_root() # Combined
    def _destroy_root(self):
        if self.root.winfo_exists(): self.root.quit(); self.root.destroy()
